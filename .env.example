# next-auth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth — create credentials at console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Botpress Tables — create an empty bot in app.botpress.cloud to get these values
# Token: Settings → API keys (Personal Access Token)
BOTPRESS_TOKEN=your-personal-access-token
BOTPRESS_WORKSPACE_ID=your-workspace-id
BOTPRESS_BOT_ID=your-bot-id

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# App URL (used for OAuth callback)
NEXTAUTH_URL=http://localhost:3000
