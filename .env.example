# Neon / Vercel Postgres
DATABASE_URL=postgres://user:password@host/dbname

# next-auth v5
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Botpress OIDC — fill in after confirming SSO details
AUTH_BOTPRESS_ISSUER=https://sso.botpress.com
AUTH_BOTPRESS_ID=your-client-id
AUTH_BOTPRESS_SECRET=your-client-secret

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# App URL (used for OIDC callback)
NEXTAUTH_URL=http://localhost:3000
